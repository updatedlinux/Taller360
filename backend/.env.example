# SQL Server (cadena ODBC-style para Prisma)
# Ejemplo:
# DATABASE_URL="sqlserver://USER:PASSWORD@HOST:1433;database=Taller360;encrypt=true;trustServerCertificate=true"
DATABASE_URL=

JWT_SECRET=cambiar-por-cadena-larga-y-aleatoria-en-produccion
JWT_EXPIRES_IN=7d

PORT=3000
NODE_ENV=development

# Orígenes CORS permitidos (coma). Vacío o * = reflejar origen (útil en desarrollo).
CORS_ORIGIN=*

# Seed opcional (npm run db:seed)
# SEED_SUPERADMIN_EMAIL=admin@empresa.com
# SEED_SUPERADMIN_PASSWORD=
